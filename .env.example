# ============================================================
#  EduScout — Environment Variables
# ============================================================

# --- Supabase (required) ------------------------------------
# Find these in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# Optional: set this in Supabase Dashboard → Database → Webhooks
# to validate that webhook POSTs actually come from Supabase
SUPABASE_WEBHOOK_SECRET=

# --- App ----------------------------------------------------
DEBUG=false
BASE_URL=http://localhost:8000
# Set PUBLIC_BASE_URL when running behind ngrok / a public domain
# PUBLIC_BASE_URL=https://your-public-url.ngrok-free.app

# --- Google OAuth (optional — needed for MCP sign-in) -------
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
MCP_OAUTH_ENABLED=true

# --- WhatsApp (optional) ------------------------------------
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=study-abroad-verify

# --- Telegram (optional) ------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=StudyAbroadAgentBot
